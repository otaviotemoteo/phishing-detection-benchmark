# =============================================================================
# Datasets - never commit raw data
# =============================================================================
data/*.csv
data/*.tsv
data/*.json
data/*.zip
data/*.tar.gz
data/*.arff
data/raw/
data/processed/
!data/dataset_hashes.json
!data/README.md
!data/.gitkeep

# =============================================================================
# Models - too large for Git, back up externally
# =============================================================================
results/models/
*.pt
*.pth
*.h5
*.joblib
*.pkl
*.pickle
*.onnx

# =============================================================================
# Experiment tracking
# =============================================================================
mlruns/
mlartifacts/
wandb/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/
.python-version-local

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# =============================================================================
# Testing & coverage
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# =============================================================================
# IDE / editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# Temporary files
# =============================================================================
*.tmp
*.bak
*.swp
*.swo
.cache/
tmp/

# =============================================================================
# Plot intermediates (keep final plots tracked)
# =============================================================================
plots/eda/*
plots/feature_importance/*
!plots/eda/.gitkeep
!plots/feature_importance/.gitkeep
# plots/final/ is intentionally NOT ignored - final figures should be tracked
